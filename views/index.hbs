<div class="deadline-banner">
    <div class="container deadline-banner-inner">
        <div class="deadline-content">
            RECCAP 2026 registration details are available | Conference dates: May 22 - 24, 2026
        </div>
    </div>
</div>

<style>
    .deadline-banner {
        background-color: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        color: white;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
        padding: 12px 0;
        position: absolute;
        top: 90px;
        width: 100%;
        font-family: var(--heading-font);
        z-index: 20;
    }

    .deadline-banner-inner {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .deadline-content {
        font-weight: 600;
        font-size: 1.1rem;
        text-align: center;
    }

    @media (max-width: 768px) {
        .deadline-banner {
            top: 82px;
        }

        .deadline-banner-inner {
            text-align: center;
        }

        .deadline-content {
            font-size: 0.95rem;
        }
    }
</style>

