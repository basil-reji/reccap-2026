<header id="header" class="header d-flex align-items-center fixed-top">
    <div class="container-fluid container-xl position-relative d-flex align-items-center justify-content-between">

        <a href="/" class="logo d-flex align-items-center">
            <span class="logo-mark" aria-hidden="true">R</span>
            <h1 class="sitename">RECCAP</h1>
        </a>

        <nav id="navmenu" class="navmenu">
            <ul>
                <li><a href="/" {{#if home }}class="active" {{/if}}>Home</a></li>
                <li><a href="/about" {{#if about }}class="active" {{/if}}>About</a></li>
                <li class="dropdown">
                    <a href="#"><span>Conference</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                    <ul>
                        <li><a href="/author-guidelines" {{#if authorGuidelines }}class="active" {{/if}}>Author Guidelines</a></li>
                        <li><a href="/camera-ready-submission" {{#if cameraReadySubmission }}class="active" {{/if}}>Camera Ready Submission</a></li>
                        <li><a href="/call-for-papers" {{#if callForPapers }}class="active" {{/if}}>Call for Papers</a></li>
                        <li><a href="/important-dates" {{#if importantDates }}class="active" {{/if}}>Important Dates</a></li>
                        <li><a href="/registration" {{#if registration }}class="active" {{/if}}>Registration</a></li>
                        <li><a href="/committee" {{#if committee }}class="active" {{/if}}>Committee</a></li>
                    </ul>
                </li>
                <li><a href="/venue" {{#if venue }}class="active" {{/if}}>Venue</a></li>
                <li><a href="/nearby-info" {{#if nearbyInfo }}class="active" {{/if}}>Nearby Info</a></li>
                <li><a href="/contact" {{#if contact }}class="active" {{/if}}>Contact</a></li>
            </ul>
            <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>

        {{#unless home}}
        <a class="btn-getstarted" href="{{registrationUrl}}" target="_blank" rel="noopener">Register Now</a>
        {{/unless}}

    </div>
</header>
